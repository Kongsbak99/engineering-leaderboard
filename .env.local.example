# MongoDB - the dashboard's own database (read/write).
# This is where engineers, scores, snapshots, go-live events etc. are stored.
# Use a connection string that has readWrite on the dashboard database.
MONGODB_URI=
MONGODB_DB_NAME=implementation-dashboard

# Optional: separate connection string for reading askLio production tenants.
# Set this if your MONGODB_URI cluster does NOT contain the tenant databases
# (e.g. dashboard writes to staging, tenants live in production). If unset,
# tenants are read from the same cluster as MONGODB_URI.
MONGODB_PROD=

# Which stage suffix to filter tenant databases by (production / staging / dev)
ASKLIO_MONGO_STAGE=production

# Optional: comma-separated list of additional tenant IDs to skip
# (on top of name-based filters for demo/workshop/sandbox/qa/etc.)
TENANT_DENYLIST=

# GitHub - org repos for PRs, commits, reviews
GITHUB_TOKEN=
GITHUB_ORG=

# Optional: comma-separated repo names within GITHUB_ORG to sync.
# If unset, the sync iterates through the org's repos (first 20 by recency).
# Example: GITHUB_REPOS=askLio or GITHUB_REPOS=askLio,docs
GITHUB_REPOS=

# Linear - issues, projects, state history
LINEAR_API_KEY=

# Cron jobs auth header (any random string; used by Vercel cron and curl)
CRON_SECRET=

# Azure Blob Storage (used to resolve tenant company logos for the dashboard)
# Same credentials as the askLio backend; pulled from askliobackendstorage
# (or your stage equivalent).
AZURE_STORAGE_ACCOUNT_URL=https://askliobackendstorage.blob.core.windows.net/
AZURE_STORAGE_ACCESS_KEY=
